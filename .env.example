# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT Config
JWT_SECRET="kno_graph_jwt_super_secret_key"

# Neo4j AuraDB Config (Optional - fell back to local file graph-storage if not provided)
NEO4J_URI=""
NEO4J_USER=""
NEO4J_PASSWORD=""

# AWS S3 Cloud Storage Config (Optional - fell back to local disk storage if not provided)
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""

# AWS OpenSearch Config (Optional - fell back to highly optimized TF-IDF local index if not provided)
OPENSEARCH_URL=""

# OAuth2 Google Login Client (Optional - simulated OAuth flow if not provided)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
